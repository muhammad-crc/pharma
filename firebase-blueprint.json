{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Medicine": {
      "title": "Medicine",
      "description": "Medicine product information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "genericName": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "dosageInfo": { "type": "string" },
        "manufacturer": { "type": "string" },
        "stock": { "type": "integer" },
        "image": { "type": "string" },
        "prescriptionRequired": { "type": "boolean" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "price", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "Medicine categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["name"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "processing", "shipped", "delivered", "cancelled"] },
        "address": { "type": "object" },
        "paymentMethod": { "type": "string" },
        "prescriptionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "Prescription": {
      "title": "Prescription",
      "description": "Uploaded medical prescriptions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "imageUrl", "status"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of app users"
    },
    "medicines": {
      "schema": "Medicine",
      "description": "Collection of pharmaceutical products"
    },
    "categories": {
      "schema": "Category",
      "description": "Collection of product categories"
    },
    "orders": {
      "schema": "Order",
      "description": "Customer orders history"
    },
    "prescriptions": {
      "schema": "Prescription",
      "description": "User prescription uploads"
    }
  }
}
